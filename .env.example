# ============================================================
# Real Estate Hedonic — 환경변수 템플릿
# 실제 사용 시 이 파일을 .env로 복사 후 값 채워 넣으세요.
# .env는 .gitignore에 포함되어 커밋되지 않습니다.
# ============================================================

# --- MOLIT 실거래가 공개 API ---
# 발급: https://www.data.go.kr/data/15057511/openapi.do  (활용신청 승인 필요)
# ⚠️ 디코딩(Decoding) serviceKey 사용. 레거시 openapi.molit.go.kr는 폐기됨.
MOLIT_API_KEY=your_molit_api_key_here
MOLIT_API_BASE=https://apis.data.go.kr/1613000/RTMSDataSvcAptTrade

# --- Kakao Local API (지오코딩용) ---
# 발급: https://developers.kakao.com/console/app
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# --- V-World (선택, 행정경계·필지 조회 시) ---
VWORLD_API_KEY=your_vworld_api_key_here

# --- 분석 대상 기본값 ---
TARGET_REGION_CODE=11680       # 강남구
TARGET_YEAR_MONTH=202601       # 2026년 1월
DATA_DIR=./data
RESULTS_DIR=./results
LOG_LEVEL=INFO
